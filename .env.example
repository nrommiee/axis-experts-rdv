NEXT_PUBLIC_SUPABASE_URL=           # URL du projet Supabase
NEXT_PUBLIC_SUPABASE_ANON_KEY=      # Clé publique Supabase (anon)
SUPABASE_SERVICE_ROLE_KEY=          # Clé service-role (serveur uniquement, ne jamais exposer)
ODOO_URL=                           # URL de l'instance Odoo (ex: https://xxx.odoo.com)
ODOO_DB=                            # Nom de la base Odoo
ODOO_USER=                          # Email utilisateur Odoo (compte API)
ODOO_API_KEY=                       # Clé API Odoo
RESEND_API_KEY=                     # Clé API Resend pour les emails transactionnels
CRON_SECRET=                        # Secret partagé pour /api/cron/* (Authorization: Bearer ...)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=    # Clé Google Maps (autocomplete adresses BE)
